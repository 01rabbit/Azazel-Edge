# Azazel-Edge Web UI configuration (.env template)
# Copy to .env and customize

# Standard Web UI
AZAZEL_WEB_HOST=127.0.0.1
AZAZEL_WEB_PORT=8084

# Arsenal-Demo (separate port)
# Uncomment and set to run Arsenal-Demo on a different port
# AZAZEL_ARSENAL_DEMO_PORT=8885
# AZAZEL_ARSENAL_DEMO_MODE=1

# Gunicorn settings
AZAZEL_WEB_WORKERS=2
AZAZEL_WEB_THREADS=4
AZAZEL_WEB_GRACEFUL_TIMEOUT=5
