#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${AZAZEL_VENV_PYTHON:-}"
if [[ -z "${PYTHON_BIN}" ]]; then
  if [[ -x "${ROOT_DIR}/.venv/bin/python" ]]; then
    PYTHON_BIN="${ROOT_DIR}/.venv/bin/python"
  else
    PYTHON_BIN="/opt/azazel-edge/venv/bin/python"
  fi
fi
if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3)"
fi
export PYTHONPATH="${ROOT_DIR}:${ROOT_DIR}/py:${PYTHONPATH:-}"
exec "${PYTHON_BIN}" -m azazel_edge.dummy_eve "$@"
