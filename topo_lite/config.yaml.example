interface: br0
subnets:
  - 172.16.0.0/24
target_ports:
  - 22
  - 53
  - 80
  - 123
  - 139
  - 443
  - 445
  - 631
  - 3389
  - 5353
  - 8000
  - 8080
  - 8443
  - 9100
database_path: topo_lite.sqlite3
logging:
  level: INFO
  app_log_path: logs/app.jsonl
  access_log_path: logs/access.jsonl
  audit_log_path: logs/audit.jsonl
  scanner_log_path: logs/scanner.jsonl
scan_intervals:
  discovery_seconds: 300
  probe_seconds: 900
  deep_probe_seconds: 60
probe:
  timeout_seconds: 2
  concurrency: 32
  retry_count: 1
  retry_backoff_seconds: 0.25
  batch_size: 64
deep_probe:
  enabled: true
  timeout_seconds: 1
  target_ports:
    - 22
    - 80
    - 443
    - 445
    - 631
    - 3389
    - 9100
  dedupe_window_seconds: 900
notification:
  enabled: false
  provider: ntfy
  endpoint: ""
  token: ""
  rate_limit_seconds: 300
integration:
  enabled: false
  queue_path: run/azazel-edge-events
auth:
  enabled: false
  mode: local
  token_required: false
  session_secret: change-me-topo-lite-session-secret
  admin_username: admin
  admin_password: change-me-admin-password
  admin_api_token: change-me-admin-token
  readonly_username: viewer
  readonly_password: change-me-viewer-password
  readonly_api_token: change-me-viewer-token
retention_period:
  observations_days: 30
  events_days: 90
  scan_runs_days: 14
exposure:
  backend_bind_host: 127.0.0.1
  frontend_bind_host: 127.0.0.1
  local_only: true
  allowed_cidrs: []
