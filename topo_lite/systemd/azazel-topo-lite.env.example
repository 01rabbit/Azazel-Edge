# Copy to /etc/default/azazel-topo-lite and adjust as needed.
AZAZEL_TOPO_LITE_CONFIG=/opt/azazel-edge/topo_lite/config.yaml
AZAZEL_TOPO_LITE_BACKEND_HOST=127.0.0.1
AZAZEL_TOPO_LITE_BACKEND_PORT=8091
AZAZEL_TOPO_LITE_FRONTEND_HOST=127.0.0.1
AZAZEL_TOPO_LITE_FRONTEND_PORT=8082
AZAZEL_TOPO_LITE_LOCAL_ONLY=true
AZAZEL_TOPO_LITE_ALLOWED_CIDRS=
AZAZEL_TOPO_LITE_INTERFACE=eth0
AZAZEL_TOPO_LITE_SCHEDULER_RETRY_LIMIT=3
AZAZEL_TOPO_LITE_SCHEDULER_RETRY_DELAY_SECONDS=10
AZAZEL_TOPO_LITE_SCHEDULER_RETRY_BACKOFF_MULTIPLIER=2.0
AZAZEL_TOPO_LITE_SCHEDULER_RETRY_MAX_DELAY_SECONDS=60
